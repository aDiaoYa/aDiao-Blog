<%
const profile = theme.profile || {};
%>
<section class="landing-hero">
  <!-- 左侧：文字内容 -->
  <div class="hero-content">
    <div class="hero-badge">Frontend × AI Agent</div>
    <h1 class="hero-name"><%= profile.name || 'aDiaoYa · 啊叼一只鱼' %></h1>
    <p class="hero-title">对于可控的事情保持谨慎，对于不可控的事情保持乐观。</p>
    <p class="hero-bio"><%= profile.bio %></p>

    <div class="hero-actions">
      <a class="btn-primary" href="<%- url_for('/home/') %>">阅读文章</a>
      <a class="btn-secondary" href="<%- url_for('/archives/') %>">查看归档</a>
    </div>
  </div>

  <!-- 右侧：p5.js 画布 -->
  <div class="hero-visual" id="hero-canvas" aria-hidden="true"></div>
  <!-- 男孩图层在最上面 -->
  <img class="star-boy-img" src="<%- url_for('/images/star-boy.png') %>" alt="爱做梦的小孩" />
</section>

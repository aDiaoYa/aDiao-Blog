<%
const profile = theme.profile || {};
%>
<section class="landing-hero">
  <!-- 左侧：文字内容 -->
  <div class="hero-content">
    <div class="hero-badge">Frontend × Agent</div>
    <h1 class="hero-name"><%= profile.name || 'aDiaoYa' %></h1>
    <p class="hero-title">Frontend Engineer · AI Agent Builder</p>
    <p class="hero-bio"><%= profile.bio %></p>

    <div class="hero-sections">
      <div class="hero-section">
        <h2>技术栈</h2>
        <div class="skill-list">
          <div class="skill-item">
            <span class="skill-name">React / Next.js</span>
            <span class="skill-bar"><i style="width:92%"></i></span>
          </div>
          <div class="skill-item">
            <span class="skill-name">TypeScript</span>
            <span class="skill-bar"><i style="width:88%"></i></span>
          </div>
          <div class="skill-item">
            <span class="skill-name">AI Agent / LLM</span>
            <span class="skill-bar"><i style="width:80%"></i></span>
          </div>
        </div>
      </div>

      <div class="hero-section">
        <h2>专注领域</h2>
        <ul class="focus-list">
          <li>前端工程化与性能优化</li>
          <li>AI Agent 工具链开发</li>
          <li>MCP 协议与工具集成</li>
        </ul>
      </div>
    </div>

    <div class="hero-actions">
      <a class="btn-primary" href="<%- url_for('/home/') %>">阅读文章</a>
      <a class="btn-secondary" href="<%- url_for('/archives/') %>">查看归档</a>
    </div>
  </div>

  <!-- 右侧：p5.js 画布 + 抱星星的男孩 -->
  <div class="hero-visual" id="hero-canvas" aria-hidden="true">
    <img class="star-boy-img" src="<%- url_for('/images/star-boy.png') %>" alt="爱做梦的小孩" />
  </div>
</section>

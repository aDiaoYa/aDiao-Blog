<% const news = site.data && site.data.news; %>

<div class="news-page">
  <div class="news-header">
    <h1>AI & 前端 · 每日资讯</h1>
    <p class="news-subtitle">
      <% if (news && news.updated) { %>
        更新时间：<%= new Date(news.updated).toLocaleString('zh-CN', {timeZone:'Asia/Shanghai'}) %> · 共 <strong><%= news.count %></strong> 条 · 按热度排名
      <% } else { %>
        资讯抓取中，请稍后再来...
      <% } %>
    </p>
  </div>

  <% if (news && news.items && news.items.length) { %>
    <!-- 工具栏 -->
    <div class="news-toolbar">
      <div class="news-filter-bar">
        <button class="nf-btn active" data-tag="全部">全部</button>
        <button class="nf-btn" data-tag="AI">🤖 AI</button>
        <button class="nf-btn" data-tag="前端">🎨 前端</button>
        <button class="nf-btn" data-tag="综合">📡 综合</button>
      </div>
      <button class="nf-translate-all" id="translate-all-btn">🌐 切换中文</button>
    </div>

    <div class="news-list">
      <% news.items.forEach(function(item, idx) { %>
        <article class="news-card" data-tags="<%= (item.tags || []).join(',') %>">
          <div class="nc-meta">
            <span class="nc-rank">#<%= idx + 1 %></span>
            <span class="nc-source"><%= item.source %></span>
            <% if (item.score) { %>
              <span class="nc-score" title="热度分数">🔥 <%= item.score %></span>
            <% } %>
            <span class="nc-date"><%= new Date(item.date).toLocaleDateString('zh-CN') %></span>
            <button class="nc-translate-btn" title="切换中/英文">🌐</button>
          </div>
          <h2 class="nc-title">
            <a href="<%= item.link %>" target="_blank" rel="noopener" class="nc-title-orig"><%= item.title %></a>
            <a href="<%= item.link %>" target="_blank" rel="noopener" class="nc-title-zh" style="display:none"><%= item.titleZh || item.title %></a>
          </h2>
          <div class="nc-tags">
            <% (item.tags || []).forEach(function(t) { %><span class="nc-tag"><%= t %></span><% }) %>
          </div>
        </article>
      <% }) %>
    </div>

    <p class="news-footer-note">
      数据来源：Hacker News、Reddit、Dev.to 等权威平台 · 每天 8:00 / 18:00 自动更新 · 标题已预翻译
    </p>
  <% } else { %>
    <div class="news-empty">
      <p>📡 正在从各大平台抓取最新 AI / 前端资讯…</p>
      <p>请稍后刷新页面，或检查 <a href="https://github.com/aDiaoYa/aDiao-Blog/actions/workflows/daily-news.yml" target="_blank">GitHub Actions</a> 抓取状态。</p>
    </div>
  <% } %>
</div>

<script>
(function() {
  // ── 标签筛选 ──
  var btns = document.querySelectorAll('.nf-btn');
  var cards = document.querySelectorAll('.news-card');
  if (btns.length && cards.length) {
    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tag = this.dataset.tag;
        btns.forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        cards.forEach(function(card) {
          if (tag === '全部') {
            card.style.display = '';
          } else {
            var cardTags = card.dataset.tags || '';
            card.style.display = cardTags.indexOf(tag) !== -1 ? '' : 'none';
          }
        });
      });
    });
  }

  // ── 中英文切换（纯显示切换，翻译数据已预存在 HTML 中）──
  var translateBtn = document.getElementById('translate-all-btn');
  var zhVisible = false;

  function setLangShow(showZh) {
    zhVisible = showZh;
    translateBtn.textContent = showZh ? '↩️ 恢复英文' : '🌐 切换中文';
    document.querySelectorAll('.news-card').forEach(function(card) {
      var origEls = card.querySelectorAll('.nc-title-orig');
      var zhEls = card.querySelectorAll('.nc-title-zh');
      origEls.forEach(function(el) { el.style.display = showZh ? 'none' : ''; });
      zhEls.forEach(function(el) { el.style.display = showZh ? '' : 'none'; });
      var btn = card.querySelector('.nc-translate-btn');
      if (btn) btn.textContent = showZh ? '↩️' : '🌐';
    });
  }

  // 单个卡片按钮
  document.querySelectorAll('.nc-translate-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var card = this.closest('.news-card');
      if (!card) return;
      var origEl = card.querySelector('.nc-title-orig');
      var zhEl = card.querySelector('.nc-title-zh');
      if (!origEl || !zhEl) return;
      var curZh = zhEl.style.display !== 'none';
      origEl.style.display = curZh ? '' : 'none';
      zhEl.style.display = curZh ? 'none' : '';
      this.textContent = curZh ? '🌐' : '↩️';
    });
  });

  // 一键切换
  if (translateBtn) {
    translateBtn.addEventListener('click', function() {
      setLangShow(!zhVisible);
    });
  }
})();
</script>

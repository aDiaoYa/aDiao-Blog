<%
var posts = page.posts ? page.posts.toArray() : [];
// 过滤掉私密文章（visibility: private）
posts = posts.filter(function(p) { return !p.visibility || p.visibility !== 'private'; });

// 收集所有分类用于筛选标签
var allCategories = {};
posts.forEach(function(p) {
  if (p.categories && p.categories.length) {
    p.categories.each(function(c) {
      if (!allCategories[c.name]) allCategories[c.name] = 0;
      allCategories[c.name]++;
    });
  }
});
var categoryKeys = Object.keys(allCategories);
%>
<section class="hero">
  <div>
    <p class="eyebrow">Frontend × Agent</p>
    <h1>文章</h1>
    <p>技术探索与生活碎片。</p>
  </div>
</section>

<% if (categoryKeys.length > 1) { %>
<nav class="category-filter" aria-label="分类筛选">
  <button class="cat-chip active" data-cat="all">全部</button>
  <% categoryKeys.forEach(function(cat) { %>
    <button class="cat-chip" data-cat="<%= cat %>"><%= cat %> <span class="cat-count"><%= allCategories[cat] %></span></button>
  <% }) %>
</nav>
<% } %>

<section class="post-list waterfall" aria-label="文章列表">
  <% if (posts.length) { %>
    <% posts.forEach(function(post) { %>
      <article class="post-card waterfall-card" data-category="<%= post.categories && post.categories.length ? post.categories.first().name : '' %>">
        <a class="post-card-link" href="<%- url_for(post.path) %>">
          <div class="post-meta">
            <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY · MM · DD') %></time>
            <% if (post.categories && post.categories.length) { %>
              <span class="post-category"><%= post.categories.first().name %></span>
            <% } %>
            <span class="meta-stat"><%= min2read(post.content) || 1 %> 分钟阅读</span>
          </div>
          <h2><%= post.title || '未命名文章' %></h2>
          <p><%= truncate(strip_html(post.excerpt || post.content || ''), { length: 150 }) %></p>
          <% if (post.tags && post.tags.length) { %>
            <div class="post-tags">
              <% post.tags.each(function(tag) { %>
                <span class="post-tag"><%= tag.name %></span>
              <% }) %>
            </div>
          <% } %>
          <span class="read-more">阅读全文 →</span>
        </a>
      </article>
    <% }) %>
  <% } else { %>
    <article class="empty-card">
      <h2>还没有发布文章</h2>
      <p>在 source/_posts 中新增 Markdown 后，这里会自动显示文章列表。</p>
    </article>
  <% } %>
</section>

<% if (categoryKeys.length > 1) { %>
<script>
(function(){
  var chips = document.querySelectorAll('.cat-chip');
  var cards = document.querySelectorAll('.waterfall-card');
  chips.forEach(function(chip) {
    chip.addEventListener('click', function() {
      var cat = this.dataset.cat;
      chips.forEach(function(c) { c.classList.remove('active'); });
      this.classList.add('active');
      cards.forEach(function(card) {
        if (cat === 'all' || card.dataset.category === cat) {
          card.style.display = '';
          setTimeout(function() { card.style.opacity = '1'; card.style.transform = ''; }, 10);
        } else {
          card.style.opacity = '0';
          card.style.transform = 'scale(0.95)';
          setTimeout(function() { card.style.display = 'none'; }, 200);
        }
      });
    });
  });
})();
</script>
<% } %>

<%- partial('partial/paginator') %>

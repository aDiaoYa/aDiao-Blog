<%
const profile = theme.profile || {};
const menu = theme.menu || {};
const social = theme.social || {};
const copyright = theme.copyright || {};
const giscus = theme.giscus || {};
const searchEnabled = theme.search && theme.search.enable;
const categoriesList = theme.categories_list || [];

// 过滤掉私密文章（visibility 为 private 的文章仅在直接链接可见）
function isPublicPost(p) {
  return !p.visibility || p.visibility !== 'private';
}
const allPosts = site.posts ? site.posts.toArray() : [];
const publicPosts = allPosts.filter(isPublicPost);
const publicRecentPosts = publicPosts.sort(function(a,b){ return b.date - a.date; }).slice(0, 5);

// 统计（仅公开文章）
const postCount = publicPosts.length;
const categoryCount = site.categories ? site.categories.filter(function(c){ return c.posts.some(isPublicPost); }).length : 0;
const tagCount = site.tags ? site.tags.filter(function(t){ return t.posts.some(isPublicPost); }).length : 0;

// 分类列表（用于侧边栏）
var sidebarCategories = [];
if (categoriesList.length) {
  // 使用配置的预设分类
  sidebarCategories = categoriesList.map(function(name) {
    var cat = site.categories.findOne({name: name});
    var count = cat ? cat.posts.filter(isPublicPost).length : 0;
    return { name: name, count: count, path: '/categories/' + name + '/' };
  });
} else {
  // 自动从文章提取
  sidebarCategories = site.categories.toArray().filter(function(c) {
    return c.posts.some(isPublicPost);
  }).sort(function(a,b) { return b.length - a.length; }).slice(0, 8).map(function(c) {
    return { name: c.name, count: c.posts.filter(isPublicPost).length, path: '/categories/' + c.name + '/' };
  });
}

// 标签云数据（仅公开文章标签）
var tagCloud = [];
if (site.tags && site.tags.length) {
  var tagsArr = site.tags.toArray().filter(function(t) {
    return t.posts.some(isPublicPost);
  });
  var maxCount = 1;
  tagsArr.forEach(function(t) {
    var cnt = t.posts.filter(isPublicPost).length;
    if (cnt > maxCount) maxCount = cnt;
  });
  tagCloud = tagsArr.sort(function(a,b) {
    var ca = a.posts.filter(isPublicPost).length;
    var cb = b.posts.filter(isPublicPost).length;
    return cb - ca;
  }).slice(0, 15).map(function(t) {
    var cnt = t.posts.filter(isPublicPost).length;
    var size = maxCount > 1 ? 0.7 + (cnt / maxCount) * 0.6 : 1;
    return { name: t.name, count: cnt, path: '/tags/' + t.name + '/', scale: size.toFixed(2) };
  });
}

const isLanding = page.layout === 'landing' || (page.path === 'index.html' && !page.posts);
const isArchive = page.layout === 'archive' || page.path === 'archives/index.html';
const isHome = page.layout === 'index' || page.path === 'home/index.html';
const isFriends = page.layout === 'friends' || page.path === 'friends/index.html';
const isNews = page.path === 'news/index.html';

// SEO meta
const pageTitle = page.title ? page.title + ' | ' + config.title : config.title;
const pageDesc = page.excerpt ? strip_html(page.excerpt).trim().substring(0, 200) : (page.description || config.description || profile.bio || '');
const pageUrl = config.url + '/' + (page.path || '');
const isPost = page.layout === 'post';
const ogImage = page.cover || page.thumbnail || (config.url + '/images/og-default.png');

// 文章过期天数（超过180天提醒）
const postAgeDays = isPost ? Math.floor((Date.now() - page.date) / (1000 * 60 * 60 * 24)) : 0;
const isOutdated = postAgeDays > 180;

// 当前文章是否为私密
const isPrivate = isPost && page.visibility === 'private';
%>
<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>" class="<%= isLanding ? 'no-dark' : '' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDesc %>">
  <meta name="keywords" content="<%= page.tags ? page.tags.map(t => t.name).join(',') : (config.keywords || '') %>">
  <meta name="author" content="<%= config.author || '' %>">

  <!-- Canonical -->
  <link rel="canonical" href="<%= pageUrl %>">

  <!-- Open Graph -->
  <meta property="og:type" content="<%= isPost ? 'article' : 'website' %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:url" content="<%= pageUrl %>">
  <meta property="og:site_name" content="<%= config.title %>">
  <meta property="og:locale" content="zh_CN">
  <% if (page.cover) { %><meta property="og:image" content="<%= ogImage %>"><% } %>
  <% if (isPost) { %>
  <meta property="article:published_time" content="<%= date_xml(page.date) %>">
  <meta property="article:author" content="<%= config.author || '' %>">
  <% if (page.tags) { page.tags.forEach(function(t) { %>
  <meta property="article:tag" content="<%= t.name %>">
  <% }) } } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDesc %>">
  <% if (page.cover) { %><meta name="twitter:image" content="<%= ogImage %>"><% } %>

  <!-- RSS -->
  <link rel="alternate" type="application/atom+xml" title="<%= config.title %> Atom Feed" href="<%- url_for('/atom.xml') %>">
  <link rel="alternate" type="application/rss+xml" title="<%= config.title %> RSS Feed" href="<%- url_for('/rss2.xml') %>">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="<%- url_for('/favicon.svg') %>">

  <link rel="stylesheet" href="<%- url_for('/css/style.css') %>">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js"></script>
</head>
<body class="<%= isLanding ? 'landing-page' : '' %><%= isHome ? ' home-page' : '' %><%= isArchive ? ' archive-page' : '' %>">
  <% if (!isLanding) { %>
  <!-- 阅读进度条 -->
  <div class="reading-progress" id="reading-progress"></div>
  <% } %>
  <div id="p5-canvas"></div>
  <% if (isLanding) { %>
    <%- body %>
  <% } else { %>
  <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="<%- url_for('/') %>" aria-label="<%= config.title %>">
          <span class="brand-icon" aria-hidden="true">&#x1F98B;</span>
          <span>
            <strong><%= config.title %></strong>
            <small><%= config.subtitle || profile.title %></small>
          </span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          <a href="<%- url_for('/') %>" class="<%= isLanding ? 'active' : '' %>">关于</a>
          <a href="<%- url_for('/home/') %>" class="<%= isHome ? 'active' : '' %>">文章</a>
          <a href="<%- url_for('/archives/') %>" class="<%= isArchive ? 'active' : '' %>">归档</a>
          <a href="<%- url_for('/news/') %>" class="<%= isNews ? 'active' : '' %>">资讯</a>
          <% if (searchEnabled) { %>
          <button class="search-btn" id="search-trigger" title="搜索" aria-label="搜索文章">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
          <% } %>
          <button class="theme-toggle" id="theme-toggle" title="切换深色/浅色模式" aria-label="切换深色/浅色模式">
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </nav>
      </header>

      <main class="<%= isHome ? 'home-main' : 'layout-grid' %>">
        <% if (isHome) { %>
          <section class="content-panel content-full">
            <%- body %>
          </section>
        <% } else { %>
          <section class="content-panel">
            <%- body %>
          </section>

          <aside class="side-panel" aria-label="博客信息">
            <section class="profile-card">
              <div class="profile-avatar">
                <span class="avatar-text">A</span>
              </div>
              <h2><%= profile.name || config.title %></h2>
              <p class="profile-bio"><%= profile.bio %></p>
              <div class="profile-tags">
                <% (theme.profile.sidebar_tags || []).forEach(function(t) { %>
                <span><%= t %></span>
                <% }) %>
              </div>
            </section>

            <section class="stats-card">
              <div class="stat-item">
                <span class="stat-num"><%= postCount %></span>
                <span class="stat-label">文章</span>
              </div>
              <div class="stat-item">
                <span class="stat-num"><%= categoryCount %></span>
                <span class="stat-label">分类</span>
              </div>
              <div class="stat-item">
                <span class="stat-num"><%= tagCount %></span>
                <span class="stat-label">标签</span>
              </div>
            </section>

            <% if (sidebarCategories.length) { %>
              <section class="mini-list sidebar-categories">
                <h3>文章分类</h3>
                <% sidebarCategories.forEach(function(cat) { %>
                  <a href="<%- url_for(cat.path) %>">
                    <span><%= cat.name %></span>
                    <span class="cat-count"><%= cat.count %></span>
                  </a>
                <% }) %>
              </section>
            <% } %>

            <% if (tagCloud.length) { %>
              <section class="tag-cloud-card">
                <h3>标签云</h3>
                <div class="tag-cloud-wrap">
                  <% tagCloud.forEach(function(t) { %>
                    <a href="<%- url_for(t.path) %>" class="tag-bubble" style="font-size:<%= (0.75 + t.scale * 0.5).toFixed(2) %>rem" title="<%= t.name %>（<%= t.count %>篇）"><%= t.name %></a>
                  <% }) %>
                </div>
              </section>
            <% } %>

            <% if (publicRecentPosts.length) { %>
              <section class="mini-list">
                <h3>近期文章</h3>
                <% publicRecentPosts.forEach(function(post) { %>
                  <a href="<%- url_for(post.path) %>">
                    <span><%= post.title || '未命名文章' %> <% if (post.visibility === 'private') { %><span class="private-badge-sm">私密</span><% } %></span>
                    <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'MM-DD') %></time>
                  </a>
                <% }) %>
              </section>
            <% } %>
          </aside>
        <% } %>
      </main>
  </div>
  <% } %>

  <!-- 回到顶部 -->
  <button class="back-to-top" id="back-to-top" title="回到顶部" aria-label="回到顶部">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6"/></svg>
  </button>

  <% if (!isLanding) { %>
  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="brand-icon">&#x1F98B;</span>
        <strong><%= config.title %></strong>
      </div>
      <div class="footer-links">
        <a href="<%- url_for('/') %>">关于</a>
        <a href="<%- url_for('/home/') %>">文章</a>
        <a href="<%- url_for('/archives/') %>">归档</a>
        <a href="<%- url_for('/news/') %>">资讯</a>
        <a href="<%- url_for('/atom.xml') %>">RSS</a>
      </div>
      <div class="footer-social">
        <% if (social.github) { %><a href="<%= social.github %>" target="_blank" rel="noopener" title="GitHub" aria-label="GitHub"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg></a><% } %>
        <% if (social.email) { %><a href="<%= social.email %>" title="Email" aria-label="Email"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></a><% } %>
        <% if (social.twitter) { %><a href="<%= social.twitter %>" target="_blank" rel="noopener" title="Twitter" aria-label="Twitter"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a><% } %>
        <% if (social.zhihu) { %><a href="<%= social.zhihu %>" target="_blank" rel="noopener" title="知乎" aria-label="知乎"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.444 20.649H21.5v1.851H6.204l2.334-5.602H6.297l2.334-5.602h2.241L8.538 16.9h2.241l2.665-6.397c1.294 1.074 2.988 1.841 4.908 2.117.264.039.528.059.796.059.553 0 1.089-.09 1.592-.255l.873 1.917a7.05 7.05 0 0 1-1.963.307 6.95 6.95 0 0 1-3.408-.907c-.9 2.306-2.001 4.424-3.438 6.208v.006z"/></svg></a><% } %>
      </div>
      <div class="footer-info">
        <span>&copy; <%= copyright.since || '2026' %><% if (new Date().getFullYear() > (copyright.since || 2026)) { %>-<%= new Date().getFullYear() %><% } %> <%= config.author %></span>
        <span class="footer-dot">·</span>
        <% if (copyright.license && copyright.license_url) { %><a href="<%= copyright.license_url %>" target="_blank" rel="noopener"><%= copyright.license %></a><% } else { %><span><%= copyright.license || 'CC BY-NC-SA 4.0' %></span><% } %>
        <span class="footer-dot">·</span>
        <span>Powered by <a href="https://hexo.io" target="_blank" rel="noopener">Hexo</a></span>
      </div>
    </div>
  </footer>
  <% } %>

  <% if (searchEnabled) { %>
  <!-- 搜索弹层 -->
  <div class="search-overlay" id="search-overlay">
    <div class="search-modal">
      <div class="search-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" id="search-input" placeholder="搜索文章..." autocomplete="off">
        <button class="search-close" id="search-close" aria-label="关闭">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="search-results" id="search-results">
        <p class="search-hint">输入关键词搜索文章</p>
      </div>
    </div>
  </div>
  <% } %>

  <script src="<%- url_for(isLanding ? '/js/sketch-landing.js' : '/js/sketch.js') %>"></script>

  <script>
  // 暗色模式切换
  (function(){
    const html = document.documentElement;
    if (html.classList.contains('no-dark')) return;
    const saved = localStorage.getItem('theme');
    if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      html.classList.add('dark');
    }
    var toggleBtn = document.getElementById('theme-toggle');
    if (!toggleBtn) return;
    toggleBtn.addEventListener('click', function() {
      html.classList.toggle('dark');
      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
    });
  })();
  </script>

  <% if (!isLanding) { %>
  <script>
  // 阅读进度条
  (function(){
    const bar = document.getElementById('reading-progress');
    if (!bar) return;
    window.addEventListener('scroll', function() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
      bar.style.width = progress + '%';
    });
  })();

  // 回到顶部
  (function(){
    const btn = document.getElementById('back-to-top');
    if (!btn) return;
    window.addEventListener('scroll', function() {
      btn.classList.toggle('visible', window.scrollY > 300);
    });
    btn.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();

  // 图片点击放大
  (function(){
    var overlay = document.createElement('div');
    overlay.className = 'img-zoom-overlay';
    overlay.innerHTML = '<img src="" alt=""><button class="img-zoom-close" aria-label="关闭">&times;</button>';
    document.body.appendChild(overlay);

    var img = overlay.querySelector('img');
    var closeBtn = overlay.querySelector('.img-zoom-close');

    overlay.addEventListener('click', function(e) {
      if (e.target === overlay || e.target === closeBtn) {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      }
    });

    document.querySelectorAll('.article-body img').forEach(function(el) {
      el.style.cursor = 'zoom-in';
      el.addEventListener('click', function() {
        img.src = el.src;
        img.alt = el.alt || '';
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });
  })();
  </script>
  <% } %>

  <% if (isPost) { %>
  <script>
  // 代码块复制按钮
  (function(){
    document.querySelectorAll('.article-body pre').forEach(function(pre) {
      var btn = document.createElement('button');
      btn.className = 'code-copy-btn';
      btn.textContent = '复制';
      btn.addEventListener('click', function() {
        var code = pre.querySelector('code') || pre;
        navigator.clipboard.writeText(code.textContent || code.innerText || '').then(function() {
          btn.textContent = '已复制';
          btn.classList.add('copied');
          setTimeout(function() {
            btn.textContent = '复制';
            btn.classList.remove('copied');
          }, 2000);
        }).catch(function() {
          btn.textContent = '复制失败';
          setTimeout(function() { btn.textContent = '复制'; }, 2000);
        });
      });
      pre.style.position = 'relative';
      pre.appendChild(btn);
    });
  })();

  </script>
  <% } %>

  <% if (searchEnabled) { %>
  <script>
  (function(){
    const overlay = document.getElementById('search-overlay');
    const trigger = document.getElementById('search-trigger');
    const closeBtn = document.getElementById('search-close');
    const input = document.getElementById('search-input');
    const results = document.getElementById('search-results');
    let searchData = null;
    let loading = false;

    trigger.addEventListener('click', () => {
      overlay.classList.add('active');
      setTimeout(() => input.focus(), 150);
      if (!searchData && !loading) loadData();
    });

    closeBtn.addEventListener('click', () => { overlay.classList.remove('active'); });
    overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('active'); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') overlay.classList.remove('active'); });

    function loadData() {
      loading = true;
      fetch('<%- url_for("/search.json") %>')
        .then(r => r.json())
        .then(d => { searchData = d; })
        .catch(() => { results.innerHTML = '<p class="search-none">搜索数据加载失败</p>'; })
        .finally(() => { loading = false; });
    }

    input.addEventListener('input', function() {
      const q = this.value.trim().toLowerCase();
      if (!q) { results.innerHTML = '<p class="search-hint">输入关键词搜索文章</p>'; return; }
      if (!searchData) { results.innerHTML = '<p class="search-hint">搜索数据加载中...</p>'; return; }

      const matched = searchData.filter(p => {
        return (p.title && p.title.toLowerCase().includes(q)) ||
               (p.text && p.text.toLowerCase().includes(q)) ||
               (p.tags && p.tags.some(t => t.toLowerCase().includes(q)));
      }).slice(0, 10);

      if (matched.length === 0) {
        results.innerHTML = '<p class="search-none">没有找到相关文章</p>';
        return;
      }

      results.innerHTML = matched.map(p => {
        let excerpt = '';
        if (p.text) {
          const idx = p.text.toLowerCase().indexOf(q);
          const start = Math.max(0, idx - 30);
          excerpt = p.text.substring(start, start + 120) + '...';
        }
        return '<a class="search-item" href="' + p.url + '"><strong>' + p.title + '</strong><span>' + excerpt + '</span></a>';
      }).join('');
    });
  })();
  </script>
  <% } %>
</body>
</html>

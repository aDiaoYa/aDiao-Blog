<%
const giscus = theme.giscus || {};
const copyright = theme.copyright || {};
var tocContent = toc(page.content, { list_number: false, max_depth: 3 });
var hasToc = tocContent && tocContent.trim().length > 0;
var isPrivate = page.visibility === 'private';
%>
<article class="article">
  <header class="article-header">
    <p class="eyebrow">
      <% if (page.categories && page.categories.length) { %>
        <%= page.categories.first().name %>
      <% } else { %>
        Article
      <% } %>
    </p>
    <h1><%= page.title || '未命名文章' %> <% if (isPrivate) { %><span class="private-badge">私密</span><% } %></h1>
    <div class="article-meta">
      <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY · MM · DD') %></time>
      <% var wc = wordcount(page.content) || 0; var mr = min2read(page.content) || 1; %>
      <span class="meta-dot">·</span><span class="meta-stat"><%= mr %> 分钟阅读</span>
      <span class="meta-dot">·</span><span class="meta-stat"><%= wc %> 字</span>
      <% if (page.tags && page.tags.length) { %>
        <span class="article-tags">
          <% page.tags.each(function(tag) { %>
            <span class="tag"><%= tag.name %></span>
          <% }) %>
        </span>
      <% } %>
    </div>
  </header>

  <div class="article-wrapper<%= hasToc ? ' has-toc' : '' %>">
    <% if (hasToc) { %>
    <aside class="article-toc">
      <h3>目录</h3>
      <%- tocContent %>
    </aside>
    <% } %>

    <div class="article-body">
      <%- page.content %>
    </div>
  </div>

  <!-- 文章过期提醒 -->
  <% var postAgeDays = Math.floor((Date.now() - page.date) / (1000 * 60 * 60 * 24)); %>
  <% if (postAgeDays > 180) { %>
  <div class="outdated-notice">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
    <span>本文发布于 <strong><%= postAgeDays %></strong> 天前，文中信息可能已过时，请注意甄别。</span>
  </div>
  <% } %>

  <!-- 版权声明 -->
  <div class="article-copyright">
    <div class="copyright-row">
      <strong>本文作者：</strong><span><%= config.author %></span>
    </div>
    <div class="copyright-row">
      <strong>本文链接：</strong><a href="<%= config.url + '/' + (page.path || '') %>"><%= config.url + '/' + (page.path || '') %></a>
    </div>
    <div class="copyright-row">
      <strong>版权声明：</strong><span>本文采用 <a href="<%= copyright.license_url || 'https://creativecommons.org/licenses/by-nc-sa/4.0/' %>" target="_blank" rel="noopener"><%= copyright.license || 'CC BY-NC-SA 4.0' %></a> 许可协议，转载请注明出处。</span>
    </div>
  </div>

  <!-- 上一篇 / 下一篇 -->
  <nav class="post-nav" aria-label="文章导航">
    <% if (page.prev) { %>
      <a class="post-nav-prev" href="<%- url_for(page.prev.path) %>">
        <span class="post-nav-label">← 上一篇</span>
        <span class="post-nav-title"><%= page.prev.title %></span>
      </a>
    <% } else { %>
      <span class="post-nav-prev post-nav-empty"></span>
    <% } %>
    <% if (page.next) { %>
      <a class="post-nav-next" href="<%- url_for(page.next.path) %>">
        <span class="post-nav-label">下一篇 →</span>
        <span class="post-nav-title"><%= page.next.title %></span>
      </a>
    <% } else { %>
      <span class="post-nav-next post-nav-empty"></span>
    <% } %>
  </nav>

  <!-- Giscus 评论 -->
  <% if (giscus.enable && giscus.repo && giscus.repo_id) { %>
  <section class="article-comments">
    <script src="https://giscus.app/client.js"
      data-repo="<%= giscus.repo %>"
      data-repo-id="<%= giscus.repo_id %>"
      data-category="<%= giscus.category || 'Announcements' %>"
      data-category-id="<%= giscus.category_id %>"
      data-mapping="<%= giscus.mapping || 'pathname' %>"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="light"
      data-lang="<%= giscus.lang || 'zh-CN' %>"
      data-loading="lazy"
      crossorigin="anonymous"
      async>
    </script>
  </section>
  <% } %>
</article>
